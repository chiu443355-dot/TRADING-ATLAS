---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'WikiWiz · Free Financial Mastery for Everyone',
  description = 'From saving your first rupee to reading live markets. 16 chapters, 5 precision calculators, live animated charts. 100% free, forever.',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#e8b84b" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet" />
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => { navigator.serviceWorker.register('/sw.js').catch(() => {}); });
    }
  </script>
  <style>
    :root {
      --bg: #03030a;
      --bg1: #06060f;
      --bg2: #0a0a18;
      --gold: #e8b84b;
      --gold2: #f5d07a;
      --green: #22c55e;
      --red: #ef4444;
      --blue: #38bdf8;
      --purple: #a78bfa;
      --teal: #2dd4bf;
      --text: #e8e8f0;
      --muted: #6b7280;
      --dim: #374151;
      --glass: rgba(255,255,255,0.03);
      --gb: rgba(255,255,255,0.07);
      --r: 14px; --rs: 8px; --rl: 20px;
    }
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { background:var(--bg); color:var(--text); font-family:'Plus Jakarta Sans',sans-serif; overflow-x:hidden; min-height:100vh; }
    ::-webkit-scrollbar { width:3px; }
    ::-webkit-scrollbar-track { background:var(--bg); }
    ::-webkit-scrollbar-thumb { background:var(--gold); border-radius:2px; }
    select option { background:#0a0a18; color:#e8e8f0; }
  </style>
</head>
<body>
  <!-- Animated dot-grid background -->
  <div aria-hidden="true" style="position:fixed;inset:0;z-index:0;pointer-events:none;background-image:radial-gradient(circle,rgba(232,184,75,0.06) 1px,transparent 1px);background-size:32px 32px;animation:gridDrift 80s linear infinite;"></div>
  <!-- Gold top accent -->
  <div aria-hidden="true" style="position:fixed;top:0;left:0;right:0;height:1px;z-index:200;background:linear-gradient(90deg,transparent,rgba(232,184,75,0.4),transparent);"></div>

  <slot />

  <style is:global>
    @keyframes gridDrift { 0%{background-position:0 0} 100%{background-position:32px 32px} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
    @keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,.3)} 50%{box-shadow:0 0 0 8px rgba(34,197,94,0)} }
    @keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
    @keyframes fabPulse { 0%,100%{box-shadow:0 8px 32px rgba(37,211,102,.4)} 50%{box-shadow:0 8px 48px rgba(37,211,102,.65)} }

    .reveal { opacity:0; transform:translateY(32px); transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1); }
    .reveal.visible { opacity:1; transform:translateY(0); }

    .card { background:var(--glass); border:1px solid var(--gb); border-radius:var(--r); padding:24px; margin-bottom:14px; transition:all .3s; }
    .card:hover { border-color:rgba(255,255,255,.12); transform:translateY(-2px); box-shadow:0 4px 32px rgba(0,0,0,.6); }
    .card h3 { font-family:'Plus Jakarta Sans',sans-serif; font-size:17px; font-weight:700; color:#fff; margin-bottom:10px; }
    .card p  { color:#9ca3af; font-size:14px; line-height:1.75; }
    .glass-gold { border-left:2px solid var(--gold) !important; }
    .glass-green { border-left:2px solid var(--green) !important; }
    .glass-red   { border-left:2px solid var(--red) !important; }
    .glass-blue  { border-left:2px solid var(--blue) !important; }
    .glass-purple{ border-left:2px solid var(--purple) !important; }
    .glass-teal  { border-left:2px solid var(--teal) !important; }

    .badge-pill { display:inline-block; font-family:'Fira Code',monospace; font-size:9px; padding:4px 10px; border-radius:50px; letter-spacing:.12em; text-transform:uppercase; margin-bottom:10px; }
    .bp-gold   { background:rgba(232,184,75,.12); color:var(--gold);   border:1px solid rgba(232,184,75,.25); }
    .bp-green  { background:rgba(34,197,94,.1);   color:var(--green);  border:1px solid rgba(34,197,94,.2); }
    .bp-red    { background:rgba(239,68,68,.1);   color:var(--red);    border:1px solid rgba(239,68,68,.2); }
    .bp-blue   { background:rgba(56,189,248,.1);  color:var(--blue);   border:1px solid rgba(56,189,248,.2); }
    .bp-purple { background:rgba(167,139,250,.1); color:var(--purple); border:1px solid rgba(167,139,250,.2); }

    .highlight-box { background:linear-gradient(135deg,rgba(232,184,75,.06),rgba(232,184,75,.02)); border:1px solid rgba(232,184,75,.18); border-radius:var(--r); padding:20px 22px; margin:20px 0; }
    .highlight-box h4 { font-family:'Fira Code',monospace; font-size:9px; letter-spacing:.3em; color:var(--gold); text-transform:uppercase; margin-bottom:8px; }
    .highlight-box p  { color:#c6a84a; font-size:14px; line-height:1.75; }
    .warn-box { background:rgba(239,68,68,.05); border:1px solid rgba(239,68,68,.18); border-radius:var(--r); padding:20px 22px; margin:20px 0; }
    .warn-box h4 { font-family:'Fira Code',monospace; font-size:9px; letter-spacing:.3em; color:var(--red); text-transform:uppercase; margin-bottom:8px; }
    .warn-box p  { color:#b87070; font-size:14px; line-height:1.75; }

    .dt { width:100%; border-collapse:collapse; font-size:13px; margin:20px 0; }
    .dt th { background:rgba(232,184,75,.05); padding:10px 16px; text-align:left; font-family:'Fira Code',monospace; font-size:9px; letter-spacing:.15em; color:var(--gold); text-transform:uppercase; border-bottom:1px solid var(--gb); }
    .dt td { padding:12px 16px; border-bottom:1px solid var(--gb); color:#9ca3af; }
    .dt tr:hover td { background:var(--glass); }

    .tl { position:relative; padding-left:28px; }
    .tl::before { content:''; position:absolute; left:8px; top:0; bottom:0; width:1px; background:var(--gb); }
    .tl-item { position:relative; margin-bottom:24px; }
    .tl-item::before { content:''; position:absolute; left:-24px; top:7px; width:9px; height:9px; border-radius:50%; background:var(--gold); border:2px solid var(--bg); }
    .tl-item h4 { font-weight:700; font-size:15px; color:#fff; margin-bottom:6px; }
    .tl-item p  { font-size:13px; color:var(--muted); }

    .accord { border:1px solid var(--gb); border-radius:var(--r); margin-bottom:8px; overflow:hidden; }
    .accord-head { padding:16px 20px; cursor:pointer; display:flex; justify-content:space-between; align-items:center; background:var(--glass); transition:background .2s; }
    .accord-head:hover { background:rgba(255,255,255,.06); }
    .accord-head .atitle { font-size:15px; font-weight:600; color:#fff; }
    .accord-head .aicon { font-size:20px; color:var(--gold); transition:transform .35s; line-height:1; }
    .accord-head.open .aicon { transform:rotate(45deg); }
    .accord-body { display:none; padding:0 20px 20px; background:var(--glass); color:#9ca3af; font-size:14px; line-height:1.8; }
    .accord-body.open { display:block; }

    .ch-eyebrow { font-family:'Fira Code',monospace; font-size:10px; letter-spacing:.4em; color:var(--gold); text-transform:uppercase; display:flex; align-items:center; gap:14px; margin-bottom:12px; }
    .ch-eyebrow::after { content:''; flex:1; height:1px; background:var(--gb); }
    .ch-title { font-family:'Playfair Display',serif; font-size:clamp(30px,5vw,54px); font-weight:700; line-height:1.05; letter-spacing:-.02em; color:#fff; margin-bottom:14px; }
    .ch-title em { font-style:italic; color:var(--gold); }
    .ch-intro { font-size:16px; color:var(--muted); max-width:620px; margin-bottom:40px; font-weight:300; line-height:1.8; }

    .stat-box { background:var(--glass); border:1px solid var(--gb); border-radius:var(--r); padding:22px; text-align:center; transition:all .3s; }
    .stat-box:hover { border-color:rgba(232,184,75,.25); transform:translateY(-2px); }
    .stat-box .val { font-family:'Playfair Display',serif; font-size:30px; color:var(--gold); display:block; }
    .stat-box .desc { font-family:'Fira Code',monospace; font-size:9px; color:var(--muted); letter-spacing:.18em; text-transform:uppercase; margin-top:6px; }

    .rule { background:var(--glass); border:1px solid var(--gb); border-radius:var(--r); padding:18px 20px; margin-bottom:10px; display:flex; gap:18px; align-items:flex-start; transition:all .3s; }
    .rule:hover { border-color:rgba(232,184,75,.2); }
    .rule .rnum { font-family:'Playfair Display',serif; font-size:32px; color:var(--gold); line-height:1; min-width:36px; opacity:.7; }
    .rule h4 { font-weight:700; font-size:15px; color:#fff; margin-bottom:5px; }
    .rule p  { font-size:13px; color:var(--muted); }

    .g2 { display:grid; grid-template-columns:repeat(auto-fit,minmax(290px,1fr)); gap:14px; }
    .g3 { display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:14px; }
    .g4 { display:grid; grid-template-columns:repeat(auto-fit,minmax(170px,1fr)); gap:12px; }

    .ch-prog { display:flex; align-items:center; gap:10px; padding:12px 18px; background:var(--glass); border:1px solid var(--gb); border-radius:var(--rs); margin-bottom:36px; }
    .ch-prog-lbl { font-family:'Fira Code',monospace; font-size:10px; color:var(--muted); letter-spacing:.15em; white-space:nowrap; }
    .ch-prog-bar { flex:1; height:3px; background:var(--bg2); border-radius:99px; overflow:hidden; }
    .ch-prog-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,var(--gold),var(--gold2)); transition:width 1.2s cubic-bezier(.22,1,.36,1); }
    .ch-prog-pct { font-family:'Fira Code',monospace; font-size:11px; color:var(--gold); font-weight:600; min-width:44px; text-align:right; }

    .quiz { background:var(--glass); border:1px solid var(--gb); border-radius:var(--rl); padding:28px; margin-top:32px; }
    .quiz-q { font-size:17px; font-weight:700; color:#fff; margin-bottom:20px; }
    .quiz-opts { display:flex; flex-direction:column; gap:10px; }
    .qopt { background:var(--bg2); border:1px solid var(--gb); border-radius:10px; padding:14px 18px; cursor:pointer; font-size:14px; color:#9ca3af; transition:all .2s; text-align:left; }
    .qopt:hover:not(:disabled) { border-color:var(--gold); color:#fff; }
    .qopt.ok  { background:rgba(34,197,94,.08); border-color:var(--green); color:var(--green); }
    .qopt.bad { background:rgba(239,68,68,.08); border-color:var(--red); color:var(--red); }
    .quiz-fb { margin-top:14px; padding:12px 16px; border-radius:10px; font-size:13px; display:none; }

    .candle-stage { display:flex; align-items:flex-end; gap:12px; padding:28px 32px; background:var(--bg1); border:1px solid var(--gb); border-radius:var(--r); justify-content:center; margin:24px 0; flex-wrap:wrap; }
    .cnd { display:flex; flex-direction:column; align-items:center; gap:2px; }
    .wick { width:2px; background:#444; border-radius:1px; }
    .cbody { border-radius:3px; min-width:18px; }
    .cnd-lbl { font-family:'Fira Code',monospace; font-size:9px; color:var(--muted); margin-top:8px; text-align:center; line-height:1.6; }

    .sess-bar { height:40px; border-radius:var(--rs); display:flex; align-items:center; padding:0 16px; font-family:'Fira Code',monospace; font-size:12px; font-weight:500; margin-bottom:8px; }
    .sess-time { margin-left:auto; font-size:10px; opacity:.65; }

    .pbg { display:grid; grid-template-columns:repeat(auto-fit,minmax(190px,1fr)); gap:12px; margin:20px 0; }
    .pbc { background:var(--glass); border:1px solid var(--gb); border-radius:var(--r); padding:18px; border-top:2px solid transparent; transition:all .3s; }
    .pbc:hover { transform:translateY(-2px); }
    .pbc h4 { font-size:14px; font-weight:700; color:#fff; margin-bottom:8px; }
    .pbc p  { font-size:12px; color:var(--muted); line-height:1.65; }

    .psych-law { background:var(--glass); border:1px solid var(--gb); border-radius:14px; padding:20px; margin-bottom:10px; border-left:3px solid var(--gold); }
    .psych-law h4 { font-size:15px; font-weight:700; color:#fff; margin-bottom:6px; }
    .psych-law p { font-size:13px; color:var(--muted); line-height:1.7; }

    .prop-card { background:var(--glass); border:1px solid var(--gb); border-radius:14px; padding:22px; }
    .prop-card h4 { font-size:16px; font-weight:700; color:#fff; margin-bottom:8px; }
    .prop-card p { font-size:13px; color:var(--muted); line-height:1.7; margin-bottom:10px; }
    .prop-badge { display:inline-block; font-family:'Fira Code',monospace; font-size:9px; padding:3px 10px; border-radius:20px; letter-spacing:.1em; }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Scroll reveal
      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
      }, { threshold:0.07, rootMargin:'0px 0px -60px 0px' });
      document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

      // Accordion
      document.querySelectorAll('.accord-head').forEach(h => {
        h.addEventListener('click', () => {
          const body = h.nextElementSibling;
          const isOpen = body.classList.contains('open');
          document.querySelectorAll('.accord-body').forEach(b => b.classList.remove('open'));
          document.querySelectorAll('.accord-head').forEach(ah => ah.classList.remove('open'));
          if (!isOpen) { body.classList.add('open'); h.classList.add('open'); }
        });
      });

      // Quiz
      document.querySelectorAll('.qopt').forEach(btn => {
        btn.addEventListener('click', function() {
          const correct = this.dataset.correct === 'true';
          const msg = this.dataset.msg || '';
          this.closest('.quiz')?.querySelectorAll('.qopt').forEach(o => o.disabled = true);
          this.classList.add(correct ? 'ok' : 'bad');
          const fb = this.closest('.quiz')?.querySelector('.quiz-fb');
          if (fb) {
            fb.style.display = 'block';
            fb.style.background = correct ? 'rgba(34,197,94,.08)' : 'rgba(239,68,68,.08)';
            fb.style.border = correct ? '1px solid rgba(34,197,94,.2)' : '1px solid rgba(239,68,68,.2)';
            fb.style.color = correct ? '#22c55e' : '#ef4444';
            fb.style.borderRadius = '10px'; fb.style.padding = '12px 16px';
            fb.textContent = msg;
          }
        });
      });
    });
  </script>

  <!-- Global i18n init — runs on every page load, applies saved locale -->
  <script>
  (function(){
    const LOCALES=['en','hi','mr'];
    function getLang(){
      try{
        const p=new URLSearchParams(location.search).get('lang');
        if(p&&LOCALES.includes(p)) return p;
        const s=localStorage.getItem('wikwiz_locale');
        if(s&&LOCALES.includes(s)) return s;
      }catch{}
      return 'en';
    }
    const lang=getLang();
    if(lang==='en') return; // default HTML is English, no fetch needed
    fetch('/locales/'+lang+'.json')
      .then(r=>r.json())
      .then(strings=>{
        document.querySelectorAll('[data-i18n]').forEach(el=>{
          const k=el.getAttribute('data-i18n');
          if(k&&strings[k]!==undefined) el.textContent=strings[k];
        });
        document.documentElement.lang=lang;
      })
      .catch(()=>{});
  })();
  </script>
</body>
</html>
