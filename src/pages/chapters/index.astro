---
import BaseLayout from '../../layouts/BaseLayout.astro';
const CHAPTERS = [
  { num:'01', name:'What Is Trading?',       tag:'Pips · Lots · Leverage',       slug:'01-what-is-trading',       icon:'📊' },
  { num:'02', name:'The Markets',             tag:'Forex · Stocks · Crypto',      slug:'02-the-markets',            icon:'🌐' },
  { num:'03', name:'Market Sessions',         tag:'When to trade',                slug:'03-market-sessions',        icon:'⏰' },
  { num:'04', name:'Market Structure',        tag:'HH/HL · BOS · CHoCH',         slug:'04-market-structure',       icon:'📈' },
  { num:'05', name:'Areas of Interest',       tag:'Support · Resistance',         slug:'05-areas-of-interest',      icon:'🎯' },
  { num:'06', name:'Candlestick Mastery',     tag:'Every reversal pattern',       slug:'06-candlestick-mastery',    icon:'🕯️' },
  { num:'07', name:'Chart Patterns',          tag:'H&S · Flags · Double top',    slug:'07-chart-patterns',         icon:'🔷' },
  { num:'08', name:'Smart Money Concepts',    tag:'Order blocks · FVGs',          slug:'08-smart-money',            icon:'🏦' },
  { num:'09', name:'Risk Management',         tag:'Stop loss · Position sizing',  slug:'09-risk-management',        icon:'🛡️' },
  { num:'10', name:'Trading Psychology',      tag:'FOMO · Revenge trading',       slug:'10-trading-psychology',     icon:'🧠' },
  { num:'11', name:'The Complete Strategy',   tag:'5-step confluence',            slug:'11-complete-strategy',      icon:'⚡' },
  { num:'12', name:'Your Roadmap',            tag:'12-month path',                slug:'12-your-roadmap',           icon:'🗺️' },
  { num:'13', name:'Options & Derivatives',   tag:'Calls · Puts · Greeks',       slug:'13-options-derivatives',    icon:'📐', advanced: true },
  { num:'14', name:'Global Macro Trading',    tag:'Central banks · Geopolitics', slug:'14-global-macro',           icon:'🌍', advanced: true },
  { num:'15', name:'Algorithmic Concepts',    tag:'Backtesting · Automation',    slug:'15-algorithmic-concepts',   icon:'🤖', advanced: true },
  { num:'16', name:'Becoming a Professional', tag:'Prop firms · FTMO · Career',  slug:'16-becoming-professional',  icon:'🏆', advanced: true },
];
---
<BaseLayout title="All 16 Chapters · WikiWiz" description="16 chapters covering everything from trading basics to prop firm evaluation. 100% free, forever.">
  <main style="max-width:960px;margin:0 auto;padding:60px 24px;position:relative;z-index:1;">
    <nav style="display:flex;align-items:center;gap:8px;font-family:'Fira Code',monospace;font-size:10px;color:var(--muted);margin-bottom:28px;">
      <a href="/" style="color:var(--gold);text-decoration:none;">WikiWiz</a>
      <span>›</span>
      <span>Chapters</span>
    </nav>
    <div class="ch-eyebrow">Full Curriculum</div>
    <h1 class="ch-title">All <em>16 Chapters</em></h1>
    <p class="ch-intro">From zero to a professional trading framework. Work through in order — each chapter builds on the last.</p>

    <div style="background:linear-gradient(135deg,rgba(167,139,250,0.06),rgba(232,184,75,0.04));border:1px solid rgba(167,139,250,0.2);border-radius:14px;padding:14px 18px;margin-bottom:28px;">
      <span style="font-family:'Fira Code',monospace;font-size:9px;color:var(--purple);letter-spacing:.3em;">✨ CHAPTERS 13–16 ARE ADVANCED</span>
      <span style="font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;color:#6b7280;margin-left:10px;">Options · Macro · Algos · Prop Firms</span>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px;">
      {CHAPTERS.map((ch, i) => (
        <a href={`/chapters/${ch.slug}`} class="reveal" style={`text-decoration:none;animation-delay:${i*0.04}s`}>
          <div style={`background:var(--glass);border:1px solid ${ch.advanced ? 'rgba(167,139,250,0.2)' : 'var(--gb)'};border-radius:14px;padding:24px;height:100%;transition:all .3s cubic-bezier(.22,1,.36,1);`}
            onmouseover="this.style.borderColor='rgba(232,184,75,.3)';this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 32px rgba(0,0,0,.5)'"
            onmouseout={`this.style.borderColor='${ch.advanced ? 'rgba(167,139,250,0.2)' : 'var(--gb)'}';this.style.transform='none';this.style.boxShadow='none'`}>
            <div style="display:flex;align-items:flex-start;gap:16px;">
              <div style="font-size:28px;flex-shrink:0;">{ch.icon}</div>
              <div style="flex:1;">
                <div style={`font-family:'Fira Code',monospace;font-size:9px;letter-spacing:.2em;margin-bottom:8px;color:${ch.advanced ? 'var(--purple)' : 'var(--gold)'}`}>
                  CHAPTER {ch.num}{ch.advanced ? ' · ADVANCED' : ''}
                </div>
                <h2 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:16px;font-weight:700;color:#fff;margin-bottom:6px;">{ch.name}</h2>
                <p style="font-family:'Fira Code',monospace;font-size:9px;color:var(--muted);letter-spacing:.06em;">{ch.tag}</p>
              </div>
              <span style="color:var(--gold);font-size:16px;opacity:.4;align-self:center;">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div style="text-align:center;margin-top:60px;padding-top:40px;border-top:1px solid var(--gb);">
      <p style="color:var(--muted);font-size:14px;margin-bottom:20px;">Ready to learn? Join our free live classes on WhatsApp.</p>
      <a href="https://wa.me/918956493671?text=I%20am%20ready%20to%20achieve%20financial%20freedom.%20Please%20enroll%20me%20in%20Raindrop." target="_blank" rel="noopener noreferrer"
         style="display:inline-flex;align-items:center;gap:10px;background:#25d366;color:#000;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:14px;padding:14px 28px;border-radius:10px;text-decoration:none;">
        Join Free Classes on WhatsApp →
      </a>
    </div>
  </main>
</BaseLayout>
