---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalculatorSuite from '../components/calculators/CalculatorSuite.tsx';
import GamificationHUD from '../components/gamification/GamificationHUD.tsx';
import LanguageSwitcher from '../components/ui/LanguageSwitcher.tsx';
import LiveMarket from '../components/ui/LiveMarket.tsx';
import EconomicCalendar from '../components/ui/EconomicCalendar.tsx';
import NewsFeed from '../components/ui/NewsFeed.tsx';
import FearGreedMeter from '../components/ui/FearGreedMeter.tsx';

const CHAPTERS = [
  { num:'01', name:'What Is Trading?',       tag:'Pips · Lots · Leverage',       slug:'01-what-is-trading',       icon:'📊', adv:false },
  { num:'02', name:'The Markets',             tag:'Forex · Stocks · Crypto',      slug:'02-the-markets',            icon:'🌐', adv:false },
  { num:'03', name:'Market Sessions',         tag:'When to trade',                slug:'03-market-sessions',        icon:'⏰', adv:false },
  { num:'04', name:'Market Structure',        tag:'HH/HL · BOS · CHoCH',         slug:'04-market-structure',       icon:'📈', adv:false },
  { num:'05', name:'Areas of Interest',       tag:'Support · Resistance',         slug:'05-areas-of-interest',      icon:'🎯', adv:false },
  { num:'06', name:'Candlestick Mastery',     tag:'Every reversal pattern',       slug:'06-candlestick-mastery',    icon:'🕯️',adv:false },
  { num:'07', name:'Chart Patterns',          tag:'H&S · Flags · Double top',    slug:'07-chart-patterns',         icon:'🔷', adv:false },
  { num:'08', name:'Smart Money Concepts',    tag:'Order blocks · FVGs',          slug:'08-smart-money',            icon:'🏦', adv:false },
  { num:'09', name:'Risk Management',         tag:'Stop loss · Position sizing',  slug:'09-risk-management',        icon:'🛡️',adv:false },
  { num:'10', name:'Trading Psychology',      tag:'FOMO · Revenge trading',       slug:'10-trading-psychology',     icon:'🧠', adv:false },
  { num:'11', name:'The Complete Strategy',   tag:'5-step confluence',            slug:'11-complete-strategy',      icon:'⚡', adv:false },
  { num:'12', name:'Your Roadmap',            tag:'12-month path',                slug:'12-your-roadmap',           icon:'🗺️',adv:false },
  { num:'13', name:'Options & Derivatives',   tag:'Calls · Puts · Greeks',       slug:'13-options-derivatives',    icon:'📐', adv:true },
  { num:'14', name:'Global Macro Trading',    tag:'Central banks · Geopolitics', slug:'14-global-macro',           icon:'🌍', adv:true },
  { num:'15', name:'Algorithmic Concepts',    tag:'Backtesting · Automation',    slug:'15-algorithmic-concepts',   icon:'🤖', adv:true },
  { num:'16', name:'Becoming a Professional', tag:'Prop firms · FTMO · Career',  slug:'16-becoming-professional',  icon:'🏆', adv:true },
];
---

<BaseLayout>

<!-- ═══════════════════ NAVBAR ═══════════════════ -->
<nav style="position:fixed;top:0;left:0;right:0;z-index:200;height:66px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 32px;background:rgba(3,3,10,0.95);backdrop-filter:blur(24px);border-bottom:1px solid rgba(232,184,75,0.08);">
  <!-- Left -->
  <div style="display:flex;align-items:center;gap:28px;">
    <a href="/chapters" data-i18n="nav.chapters" style="font-family:'Fira Code',monospace;font-size:11px;color:var(--muted);text-decoration:none;letter-spacing:.08em;transition:color .2s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">Chapters</a>
    <a href="/calculators" data-i18n="nav.calculators" style="font-family:'Fira Code',monospace;font-size:11px;color:var(--muted);text-decoration:none;letter-spacing:.08em;transition:color .2s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">Calculators</a>
    <a href="#live" data-i18n="nav.live" style="font-family:'Fira Code',monospace;font-size:11px;color:var(--muted);text-decoration:none;letter-spacing:.08em;transition:color .2s;" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">Live</a>
  </div>
  <!-- Center Logo -->
  <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:10px;justify-content:center;">
    <svg width="38" height="38" viewBox="0 0 38 38" fill="none">
      <circle cx="19" cy="19" r="18" stroke="#e8b84b" stroke-width="1" stroke-opacity="0.35"/>
      <circle cx="19" cy="19" r="18" stroke="url(#rg)" stroke-width="1" stroke-opacity="0.5"/>
      <!-- Candle 1 green -->
      <rect x="8"  y="21" width="5" height="9"  rx="1.2" fill="#22c55e" fill-opacity="0.92"/>
      <line x1="10.5" y1="19" x2="10.5" y2="21" stroke="#22c55e" stroke-width="1.5"/>
      <line x1="10.5" y1="30" x2="10.5" y2="32" stroke="#22c55e" stroke-width="1.5"/>
      <!-- Candle 2 gold -->
      <rect x="16" y="13" width="5" height="12" rx="1.2" fill="#e8b84b" fill-opacity="0.95"/>
      <line x1="18.5" y1="10" x2="18.5" y2="13" stroke="#e8b84b" stroke-width="1.5"/>
      <line x1="18.5" y1="25" x2="18.5" y2="28" stroke="#e8b84b" stroke-width="1.5"/>
      <!-- Candle 3 red -->
      <rect x="24" y="17" width="5" height="8"  rx="1.2" fill="#ef4444" fill-opacity="0.9"/>
      <line x1="26.5" y1="14" x2="26.5" y2="17" stroke="#ef4444" stroke-width="1.5"/>
      <line x1="26.5" y1="25" x2="26.5" y2="28" stroke="#ef4444" stroke-width="1.5"/>
      <!-- Trend line -->
      <polyline points="10,28 18,20 29,15" stroke="#e8b84b" stroke-width="1.2" fill="none" stroke-opacity="0.5" stroke-dasharray="2,2"/>
      <circle cx="29" cy="15" r="2.2" fill="#e8b84b"/>
      <defs>
        <radialGradient id="rg" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#e8b84b" stop-opacity="0.6"/>
          <stop offset="100%" stop-color="#e8b84b" stop-opacity="0"/>
        </radialGradient>
      </defs>
    </svg>
    <div>
      <div style="font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:#e8b84b;line-height:1;letter-spacing:-.02em;">WikiWiz</div>
      <div style="font-family:'Fira Code',monospace;font-size:7px;color:rgba(232,184,75,0.45);letter-spacing:.3em;text-transform:uppercase;margin-top:2px;">Financial Mastery</div>
    </div>
  </a>
  <!-- Right -->
  <div style="display:flex;align-items:center;gap:14px;justify-content:flex-end;">
    <LanguageSwitcher client:load />
    <a href="#join" data-i18n="nav.join" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;font-weight:700;color:#000;background:linear-gradient(135deg,#e8b84b,#f5d07a);padding:9px 20px;border-radius:9px;text-decoration:none;transition:all .2s;box-shadow:0 4px 16px rgba(232,184,75,0.25);" onmouseover="this.style.transform='translateY(-1px)'" onmouseout="this.style.transform='none'">Join Free</a>
  </div>
</nav>

<main style="position:relative;z-index:1;">

<!-- ═══════════════════ HERO ═══════════════════ -->
<section style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:100px 32px 60px;text-align:center;position:relative;overflow:hidden;">
  <!-- Radial glow -->
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:600px;background:radial-gradient(circle,rgba(232,184,75,0.06) 0%,transparent 70%);pointer-events:none;"></div>

  <div style="max-width:820px;position:relative;">
    <!-- Badge -->
    <div style="display:inline-flex;align-items:center;gap:8px;font-family:'Fira Code',monospace;font-size:9px;letter-spacing:.45em;color:var(--gold);background:rgba(232,184,75,.06);border:1px solid rgba(232,184,75,.18);padding:8px 18px;border-radius:50px;margin-bottom:36px;" data-i18n="hero.tag">FREE · FOREVER · FOR EVERYONE</div>

    <!-- Title -->
    <h1 style="font-family:'Playfair Display',serif;font-size:clamp(56px,10vw,112px);font-weight:700;line-height:.92;letter-spacing:-.04em;color:#fff;margin-bottom:0;">
      <span data-i18n="hero.line1" style="display:block;">WikiWiz</span>
      <em style="color:var(--gold);font-style:italic;display:block;" data-i18n="hero.line2">Financial Mastery</em>
    </h1>

    <!-- Subtitle -->
    <p style="font-size:17px;color:var(--muted);max-width:580px;margin:28px auto 40px;line-height:1.8;font-weight:300;" data-i18n="hero.sub">
      From saving your first rupee to reading live markets. 16 chapters. 5 precision calculators. Live animated charts. Built for everyone across the world.
    </p>

    <!-- CTAs -->
    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:60px;">
      <a href="#join" style="display:inline-flex;align-items:center;gap:10px;background:#25d366;color:#000;font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:15px;padding:16px 32px;border-radius:12px;text-decoration:none;transition:all .25s;box-shadow:0 8px 32px rgba(37,211,102,.3);animation:fabPulse 3s ease-in-out infinite;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a9 9 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span data-i18n="hero.cta">Join Free Classes</span>
      </a>
      <a href="#live" style="display:inline-flex;align-items:center;gap:8px;background:rgba(232,184,75,.08);color:var(--gold);font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:15px;padding:16px 28px;border-radius:12px;text-decoration:none;border:1px solid rgba(232,184,75,.2);transition:all .25s;" onmouseover="this.style.background='rgba(232,184,75,.14)'" onmouseout="this.style.background='rgba(232,184,75,.08)'">
        📈 <span data-i18n="hero.charts">Live Charts</span>
      </a>
    </div>

    <!-- Stats row -->
    <div style="display:flex;gap:0;justify-content:center;border:1px solid rgba(255,255,255,0.07);border-radius:16px;overflow:hidden;background:rgba(255,255,255,0.02);max-width:580px;margin:0 auto;">
      {[
        { val:'16', k:'hero.stat1', fb:'Chapters' },
        { val:'180+', k:'hero.stat2', fb:'Concepts' },
        { val:'₹0', k:'hero.stat3', fb:'Cost Forever' },
        { val:'$7.5T', k:'hero.stat4', fb:'Forex Daily Vol' },
      ].map((s,i) => (
        <div style={`flex:1;padding:20px 12px;text-align:center;${i<3?'border-right:1px solid rgba(255,255,255,0.07)':''}`}>
          <div style="font-family:'Playfair Display',serif;font-size:26px;color:var(--gold);font-weight:700;">{s.val}</div>
          <div style="font-family:'Fira Code',monospace;font-size:8px;color:var(--muted);letter-spacing:.18em;text-transform:uppercase;margin-top:4px;" data-i18n={s.k}>{s.fb}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════ LIVE MARKETS ═══════════════════ -->
<section id="live" style="padding:80px 32px;max-width:1300px;margin:0 auto;">
  <div class="ch-eyebrow" data-i18n="section.live">Live Markets</div>
  <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,48px);color:#fff;margin-bottom:8px;">
    Real-Time <em style="color:var(--gold);font-style:italic;">Animated Charts</em>
  </h2>
  <p style="color:var(--muted);font-size:14px;margin-bottom:32px;">Canvas-rendered candlesticks ticking every 0.8 seconds. 6 live instruments.</p>

  <LiveMarket client:load />

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:20px;margin-top:24px;">
    <EconomicCalendar client:visible />
    <div style="display:flex;flex-direction:column;gap:20px;">
      <FearGreedMeter client:visible />
      <NewsFeed client:visible />
    </div>
  </div>
</section>

<!-- ═══════════════════ CHAPTERS ═══════════════════ -->
<section id="chapters" style="padding:80px 32px;max-width:1300px;margin:0 auto;">
  <div class="ch-eyebrow" data-i18n="section.chapters">Full Curriculum</div>
  <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,48px);color:#fff;margin-bottom:8px;">
    <em style="color:var(--gold);font-style:italic;">16 Chapters</em> — Zero to Professional
  </h2>
  <p style="color:var(--muted);font-size:14px;margin-bottom:28px;">From basics to prop firm evaluation — complete curriculum, free forever.</p>

  <!-- Advanced banner -->
  <div style="display:flex;align-items:center;gap:14px;background:linear-gradient(135deg,rgba(167,139,250,0.06),rgba(232,184,75,0.04));border:1px solid rgba(167,139,250,0.2);border-radius:12px;padding:12px 18px;margin-bottom:24px;">
    <span style="font-size:18px;">✨</span>
    <div>
      <div style="font-family:'Fira Code',monospace;font-size:8px;color:var(--purple);letter-spacing:.3em;margin-bottom:2px;">NEW — CHAPTERS 13–16</div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;color:#6b7280;">Options & Derivatives · Global Macro · Algorithmic Concepts · Becoming a Professional</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:12px;">
    {CHAPTERS.map((ch,i)=>(
      <a href={`/chapters/${ch.slug}`} class="reveal" style={`text-decoration:none;transition-delay:${i*0.025}s`}>
        <div class={`ch-card${ch.adv?' ch-card-adv':''}`}
          onmouseover="this.classList.add('ch-card-hover')"
          onmouseout="this.classList.remove('ch-card-hover')">
          <div style="display:flex;align-items:flex-start;gap:12px;">
            <span style="font-size:24px;flex-shrink:0;line-height:1;">{ch.icon}</span>
            <div style="flex:1;min-width:0;">
              <div style={`font-family:'Fira Code',monospace;font-size:8px;letter-spacing:.2em;margin-bottom:5px;color:${ch.adv?'var(--purple)':'var(--gold)'}`}>
                CH {ch.num}{ch.adv?' · ADV':''}
              </div>
              <div style="font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:700;color:#fff;margin-bottom:4px;line-height:1.3;">{ch.name}</div>
              <div style="font-family:'Fira Code',monospace;font-size:8px;color:var(--muted);letter-spacing:.04em;">{ch.tag}</div>
            </div>
            <span style="color:var(--gold);font-size:13px;opacity:.3;align-self:center;flex-shrink:0;">→</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ═══════════════════ CALCULATORS ═══════════════════ -->
<section id="calculators" style="padding:80px 32px;max-width:1300px;margin:0 auto;">
  <div class="ch-eyebrow" data-i18n="section.calcs">Trading Tools</div>
  <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,48px);color:#fff;margin-bottom:8px;">
    5 Precision <em style="color:var(--gold);font-style:italic;">Calculators</em>
  </h2>
  <p style="color:var(--muted);font-size:14px;margin-bottom:0;">Share results to WhatsApp in one tap. Earn +25 XP per share.</p>
  <CalculatorSuite client:visible />
</section>

<!-- ═══════════════════ PROGRESS ═══════════════════ -->
<section id="progress" style="padding:60px 32px 80px;max-width:1300px;margin:0 auto;">
  <div class="ch-eyebrow" data-i18n="section.progress">Your Progress</div>
  <h2 style="font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,48px);color:#fff;margin-bottom:8px;">
    Track Your <em style="color:var(--gold);font-style:italic;">Journey</em>
  </h2>
  <GamificationHUD client:visible />
</section>

<!-- ═══════════════════ JOIN RAINDROP ═══════════════════ -->
<section id="join" style="padding:100px 32px 120px;max-width:780px;margin:0 auto;text-align:center;">
  <div style="display:inline-flex;align-items:center;gap:8px;font-family:'Fira Code',monospace;font-size:9px;letter-spacing:.4em;color:var(--green);background:rgba(34,197,94,.06);border:1px solid rgba(34,197,94,.15);padding:8px 18px;border-radius:50px;margin-bottom:28px;" data-i18n="join.badge">FREE · FOREVER · NO CATCH</div>

  <h2 style="font-family:'Playfair Display',serif;font-size:clamp(40px,7vw,80px);color:#fff;line-height:1;margin-bottom:16px;" data-i18n="join.h">Join Raindrop</h2>
  <p style="color:var(--muted);font-size:16px;max-width:500px;margin:0 auto 52px;line-height:1.85;" data-i18n="join.sub">
    We teach saving money, investing, basic markets, and full trading — from scratch. For women across the world and anyone who wants in.
  </p>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:16px;margin-bottom:52px;text-align:left;">
    {[
      { n:'01', h:'join.step1', hfb:'Click the button below', d:'join.step1d', dfb:'Opens WhatsApp directly.' },
      { n:'02', h:'join.step2', hfb:'Just hit Send',          d:'join.step2d', dfb:'No forms, no payment.' },
      { n:'03', h:'join.step3', hfb:"You're enrolled",        d:'join.step3d', dfb:'We send the schedule immediately.' },
    ].map(s=>(
      <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:22px;">
        <div style="font-family:'Playfair Display',serif;font-size:36px;color:var(--gold);line-height:1;margin-bottom:10px;font-style:italic;">{s.n}</div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:700;color:#fff;margin-bottom:6px;" data-i18n={s.h}>{s.hfb}</h3>
        <p style="font-size:12px;color:var(--muted);line-height:1.6;" data-i18n={s.d}>{s.dfb}</p>
      </div>
    ))}
  </div>

  <a href="https://wa.me/918956493671?text=I%20am%20ready%20to%20achieve%20financial%20freedom.%20Please%20enroll%20me%20in%20Raindrop." target="_blank" rel="noopener noreferrer"
     style="display:inline-flex;align-items:center;gap:12px;background:#25d366;color:#000;font-family:'Plus Jakarta Sans',sans-serif;font-weight:800;font-size:16px;padding:20px 40px;border-radius:14px;text-decoration:none;box-shadow:0 8px 40px rgba(37,211,102,.4);animation:fabPulse 2.5s ease-in-out infinite;transition:transform .25s;"
     onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='none'">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a9 9 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    <span data-i18n="join.cta">Enroll Now on WhatsApp — It's Free</span>
  </a>
</section>

<!-- ═══════════════════ FOOTER ═══════════════════ -->
<footer style="border-top:1px solid rgba(255,255,255,0.06);padding:40px 32px;text-align:center;">
  <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:16px;">
    <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
      <rect x="8" y="20" width="4" height="9" rx="1" fill="#22c55e" fill-opacity="0.8"/>
      <rect x="15" y="13" width="4" height="12" rx="1" fill="#e8b84b" fill-opacity="0.9"/>
